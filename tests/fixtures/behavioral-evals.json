{
  "schemaVersion": 1,
  "purpose": "Deterministic Naru behavioral contract corpus; not a live model-quality benchmark.",
  "cases": [
    {
      "id": "narrow-implementation",
      "workflow": "implementation",
      "rootAgent": "naru-orchestrator",
      "input": { "summary": "Add a label to one known component." },
      "selection": { "baseline": ["naru-minion-implement", "naru-minion-verify", "naru-minion-judge"], "selected": ["naru-minion-implement", "naru-minion-verify", "naru-minion-judge"], "skipped": ["naru-minion-scout", "naru-minion-investigate", "naru-minion-architect", "naru-minion-debug"], "skippedStatus": "skipped-not-relevant" },
      "routing": { "root": { "profile": "sol", "variant": "high" }, "children": { "profiles": ["luna", "terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["unrelated refactor", "automatic xhigh escalation"], "routes": ["naru-delegate-sol-xhigh-minion-implement"] },
      "expected": { "status": "completed", "authorization": "authorized-local" }
    },
    {
      "id": "cross-package-implementation",
      "workflow": "implementation",
