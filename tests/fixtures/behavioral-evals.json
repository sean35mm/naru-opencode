      "prohibited": { "actions": ["invent a root cause", "edit files"], "routes": ["naru-delegate-sol-xhigh-minion-debug"] },
      "expected": { "status": "clarification-required", "authorization": "read-only" }
    },
    {
      "id": "security-data-sensitive-change",
      "workflow": "plan",
      "rootAgent": "naru-plan",
      "input": { "summary": "Add retention handling for customer account data." },
      "selection": { "baseline": ["naru-plan-minimal-change", "naru-plan-tests", "naru-plan-judge"], "selected": ["naru-plan-architecture", "naru-plan-minimal-change", "naru-plan-risk", "naru-plan-tests", "naru-plan-judge"], "skipped": [], "skippedStatus": "skipped-not-relevant" },
      "routing": { "root": { "profile": "terra", "variant": "high" }, "children": { "profiles": ["terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["read secrets", "run migration"], "routes": ["naru-delegate-sol-xhigh-minion-implement"] },
      "expected": { "status": "completed", "authorization": "read-only" }
    },
    {
      "id": "frontend-review",
      "workflow": "review",
