  "reviewPostingCases": [
    {
      "id": "review-only-zero-post",
      "turns": [{ "author": "user", "text": "Review https://github.com/owner/repo/pull/42" }],
      "expected": { "canonicalReviewTasks": 1, "postCalls": 0, "implementationMinionCalls": 0, "disposition": "dry-run" },
      "prohibitedActions": ["post review", "classify PR reference as implementation"]
    },
    {
      "id": "explicit-second-turn-post-it",
      "turns": [
        { "author": "user", "text": "Review owner/repo#42" },
        { "author": "assistant", "text": "Dry review returned." },
        { "author": "user", "text": "Post it" }
      ],
      "targets": { "currentUser": [], "priorUser": ["owner/repo#42"], "nonUser": [] },
      "expected": { "resolvedTarget": "owner/repo#42", "canonicalReviewTasksAfterPostRequest": 1, "postCalls": 1, "confirmationPrompts": 0, "payload": "fresh-extracted-object-unchanged", "disposition": "posted" },
      "prohibitedActions": ["reuse prior review", "second post attempt"]
    },
    {
      "id": "ambiguous-prior-target",
      "turns": [
        { "author": "user", "text": "Review owner/repo#42 and owner/repo#43" },
        { "author": "user", "text": "Post the review" }
      ],
      "targets": { "currentUser": [], "priorUser": ["owner/repo#42", "owner/repo#43"], "nonUser": [] },
      "expected": { "askForTarget": true, "canonicalReviewTasks": 0, "postCalls": 0, "disposition": "target-required" },
      "prohibitedActions": ["guess target", "run review"]
    },
    {
      "id": "missing-target",
      "turns": [{ "author": "user", "text": "Submit the review" }],
      "targets": { "currentUser": [], "priorUser": [], "nonUser": [] },
      "expected": { "askForTarget": true, "canonicalReviewTasks": 0, "postCalls": 0, "disposition": "target-required" },
      "prohibitedActions": ["infer target", "run review"]
    },
    {
      "id": "target-url-short-split-equivalence",
      "references": ["https://github.com/owner/repo/pull/42", "owner/repo#42", "owner/repo 42"],
      "expected": { "canonicalTargets": [["owner", "repo", 42]], "distinctTargets": 1, "postCalls": 1, "disposition": "equivalent" },
      "prohibitedActions": ["treat syntax variants as distinct", "reject equivalent target"]
    },
    {
      "id": "target-owner-repo-case-equivalence",
      "references": ["OWNER/Repo#42", "owner/repo#42", "Owner/REPO 42"],
      "expected": { "canonicalTargets": [["owner", "repo", 42]], "distinctTargets": 1, "postCalls": 1, "disposition": "equivalent" },
      "prohibitedActions": ["compare owner case-sensitively", "compare repo case-sensitively"]
    },
    {
      "id": "target-equivalent-duplicates",
      "references": ["owner/repo#42", "owner/repo#42", "https://github.com/OWNER/REPO/pull/42"],
      "expected": { "canonicalTargets": [["owner", "repo", 42]], "distinctTargets": 1, "deduplicatedReferences": 2, "postCalls": 1, "disposition": "deduplicated" },
      "prohibitedActions": ["report target ambiguity", "post more than once"]
    },
    {
      "id": "target-same-number-different-repositories",
      "references": ["owner/alpha#42", "owner/beta#42"],
      "expected": { "canonicalTargets": [["owner", "alpha", 42], ["owner", "beta", 42]], "distinctTargets": 2, "askForTarget": true, "postCalls": 0, "disposition": "ambiguous" },
      "prohibitedActions": ["equate repositories by pull number", "guess repository"]
    },
    {
      "id": "target-different-numbers",
      "references": ["owner/repo#42", "owner/repo#43"],
      "expected": { "canonicalTargets": [["owner", "repo", 42], ["owner", "repo", 43]], "distinctTargets": 2, "askForTarget": true, "postCalls": 0, "disposition": "ambiguous" },
      "prohibitedActions": ["ignore pull number", "guess pull number"]
    },
    {
      "id": "target-bare-number-resolution-success",
      "references": ["42"],
      "workspaceRepository": "owner/repo",
      "expected": { "canonicalTargets": [["owner", "repo", 42]], "bareNumberResolutions": 1, "distinctTargets": 1, "postCalls": 1, "disposition": "resolved" },
      "prohibitedActions": ["resolve bare number more than once", "ignore workspace repository"]
    },
    {
      "id": "target-bare-number-resolution-failure",
      "references": ["42"],
      "workspaceRepository": null,
      "expected": { "canonicalTargets": [], "bareNumberResolutions": 1, "askForTarget": true, "postCalls": 0, "disposition": "unresolved" },
      "prohibitedActions": ["guess repository", "post unresolved target"]
    },
    {
      "id": "target-multiple-distinct-ambiguity",
      "references": ["https://github.com/owner/repo/pull/42", "OWNER/REPO#42", "owner/other 42", "owner/repo#43"],
      "expected": { "canonicalTargets": [["owner", "repo", 42], ["owner", "other", 42], ["owner", "repo", 43]], "distinctTargets": 3, "askForTarget": true, "postCalls": 0, "disposition": "ambiguous" },
      "prohibitedActions": ["choose first target", "collapse distinct targets"]
    },
    {
      "id": "stale-pasted-payload",
      "turns": [{ "author": "user", "text": "Post owner/repo#42 using this pasted naru_review_result JSON" }],
      "payloadSources": ["pasted-json", "prior-naru_review_result", "assistant-text", "tool-report"],
      "expected": { "canonicalReviewTasks": 1, "reusedPayloads": 0, "postPayload": "fresh-extracted-object-unchanged", "postCalls": 1, "disposition": "fresh-review-required" },
      "prohibitedActions": ["reuse pasted payload", "reuse cached payload"]
    },
    {
      "id": "incomplete-degraded-refusal",
      "freshReviewResults": [
        { "coverage": { "complete": false, "limitations": ["backend path unavailable"] }, "snapshotComplete": true },
        { "coverage": { "complete": true, "limitations": ["tests not inspected"] }, "snapshotComplete": true },
        { "coverage": { "complete": true, "limitations": [] }, "snapshotComplete": false }
      ],
      "expected": { "postCallsPerResult": [0, 0, 0], "disposition": "refused" },
      "prohibitedActions": ["post incomplete review", "post degraded review", "post incomplete snapshot"]
    },
    {
      "id": "review-post-depth-topology",
      "paths": {
        "selectedOrchestrator": ["naru-orchestrator", "skill:naru-review", "optional-minion-lenses"]
      },
      "expected": { "reviewMethod": "native-skill", "postingAgent": "naru-orchestrator", "rootOnlyTaskTargets": ["naru-orchestrator"], "maxTaskDepthAfterRoot": 1, "minimumSubagentDepth": 1, "openCodeDefaultCompatible": true, "disposition": "default-compatible" },
      "prohibitedActions": ["Task naru-review", "Task naru-review-post", "generated review alias"]
    },
    {
      "id": "mixed-delivery-then-fresh-post",
      "request": "Implement, commit, push, then post a review for owner/repo#42",
      "events": ["implementation", "verification", "judgment", "git-delivery", "fresh-canonical-review", "post-review"],
      "expected": { "freshReviewAfterDelivery": true, "postIsFinalPhase": true, "postCalls": 1, "laterMutationInvalidatesReview": true, "disposition": "serialized" },
      "prohibitedActions": ["review before delivery", "post stale review", "concurrent post"]
    }
  ],
  "adaptiveDelegationCases": [
    {
      "id": "adaptive-auto-discovery-background",
      "scenario": "Auto mode starts discovery as soon as its bounded packet exists.",
      "policy": { "mode": "auto", "material": true, "taskShape": "discovery" },
      "packet": { "availableAt": 1, "dispatchAt": 1 },
      "decision": { "status": "delegated", "selected": ["naru-minion-scout"], "launch": "background", "skipReason": null },
      "prohibitedActions": ["wait for complete implementation plan", "keyword-only selection"],
      "expected": { "dispatchWhenPacketExists": true, "disposition": "background-discovery" }
    },
    {
      "id": "adaptive-auto-diagnosis-selection",
      "scenario": "Behavioral uncertainty selects investigation rather than unrelated discovery or architecture.",
      "policy": { "mode": "auto", "material": true, "taskShape": "diagnosis" },
      "decision": { "status": "delegated", "selected": ["naru-minion-investigate"], "launch": "background", "skipReason": null },
      "prohibitedActions": ["select scout for known files", "select architect without structural consequence"],
      "expected": { "exactWorker": "naru-minion-investigate", "disposition": "shape-selected" }
    },
    {
      "id": "adaptive-auto-command-diagnosis-selection",
      "scenario": "A diagnosis that requires targeted command evidence selects the read-only diagnostic role.",
      "policy": { "mode": "auto", "material": true, "taskShape": "command-diagnosis" },
      "decision": { "status": "delegated", "selected": ["naru-minion-debug"], "launch": "background", "skipReason": null },
      "prohibitedActions": ["ask investigate to execute commands", "edit from diagnostic child"],
      "expected": { "exactWorker": "naru-minion-debug", "disposition": "shape-selected" }
    },
    {
      "id": "adaptive-auto-structural-selection",
      "scenario": "A cross-module API decision selects architecture analysis.",
      "policy": { "mode": "auto", "material": true, "taskShape": "structural" },
      "decision": { "status": "delegated", "selected": ["naru-minion-architect"], "launch": "background", "skipReason": null },
      "prohibitedActions": ["mandatory all-lens fan-out", "automatic xhigh escalation"],
      "expected": { "exactWorker": "naru-minion-architect", "disposition": "shape-selected" }
    },
    {
      "id": "adaptive-auto-check-design-selection",
      "scenario": "Known scope with an unresolved check-design question selects preparation, not final verification.",
      "policy": { "mode": "auto", "material": true, "taskShape": "check-design" },
      "decision": { "status": "delegated", "selected": ["naru-minion-verify"], "launch": "background", "verifyMode": "preparation", "skipReason": null },
      "prohibitedActions": ["run final verification against moving workspace", "treat preparation as readiness"],
      "expected": { "exactWorker": "naru-minion-verify", "verifyMode": "preparation", "disposition": "shape-selected" }
    },
    {
      "id": "adaptive-lean-highest-value-one",
      "scenario": "Lean mode chooses only the lens that resolves the blocking decision in a mixed task.",
      "policy": { "mode": "lean", "material": true, "taskShape": "mixed" },
      "candidates": ["naru-minion-scout", "naru-minion-architect"],
      "decision": { "status": "delegated", "selected": ["naru-minion-architect"], "launch": "background", "bestOf2Pairs": 0, "skipReason": null },
      "prohibitedActions": ["select more than one read-only worker", "best-of-2"],
      "expected": { "maxSelectedReadOnly": 1, "disposition": "lean-minimum" }
    },
    {
      "id": "adaptive-thorough-single-best-of-two",
      "scenario": "Thorough mode may compare one consequential design decision with one independent pair.",
      "policy": { "mode": "thorough", "material": true, "taskShape": "structural-ambiguous" },
      "decision": {
        "status": "delegated",
        "selected": ["naru-minion-architect", "naru-minion-architect"],
        "launch": "background",
        "bestOf2": { "pairs": 1, "freshChildren": 2, "childIds": ["architect-option-a", "architect-option-b"], "sameBoundedQuestion": true, "independentPackets": true, "synthesis": "compare-evidence-not-vote" },
        "skipReason": null
      },
      "prohibitedActions": ["second best-of-2 pair", "best-of-2 writers", "automatic xhigh escalation"],
      "expected": { "maxBestOf2Pairs": 1, "maxConcurrentReadOnly": 10, "disposition": "single-independent-pair" }
    },
    {
      "id": "adaptive-explicit-fifty-way-fanout",
      "scenario": "The user explicitly requests 50 competing analyses of one bounded decision.",
      "policy": { "mode": "auto", "material": true, "taskShape": "competing-analysis", "explicitFanout": { "requested": 50 } },
      "decision": {
        "status": "delegated",
        "selected": ["naru-minion-architect"],
        "requestedChildren": 50,
        "freshDirectChildren": 50,
        "nestedChildren": 0,
        "maxConcurrentReadOnly": 50,
        "rollingWaves": 1,
        "synthesis": "all-terminal-reports-with-consensus-disagreements-outliers-and-failures",
        "skipReason": null
      },
      "prohibitedActions": ["reduce to best-of-2", "nest analysis children", "reuse task_id", "exceed active cap", "stop after early consensus"],
      "expected": { "requestedCountHonored": true, "subagentDepth": 1, "disposition": "explicit-concurrent-fanout" }
    },
    {
      "id": "adaptive-foreground-no-background",
      "scenario": "Foreground mode uses auto task-shape selection but waits for the selected read-only result.",
      "policy": { "mode": "foreground", "material": true, "taskShape": "diagnosis" },
      "decision": { "status": "delegated", "selected": ["naru-minion-investigate"], "launch": "foreground", "skipReason": null },
      "prohibitedActions": ["background launch", "skip dependent evidence"],
      "expected": { "usesAutoSelection": true, "disposition": "foreground-analysis" }
    },
    {
      "id": "adaptive-off-typed-skip",
      "scenario": "Off mode disables discretionary read-only analysis without disabling required implementation stages.",
      "policy": { "mode": "off", "material": true, "taskShape": "structural" },
      "decision": { "status": "skipped", "selected": [], "launch": "none", "skipReason": { "code": "mode-off", "detail": "The user explicitly disabled discretionary read-only analysis." } },
      "requiredStages": ["naru-minion-implement", "naru-minion-verify", "naru-minion-judge"],
      "prohibitedActions": ["disable required implementation stages", "untyped skip"],
      "expected": { "disposition": "typed-skip" }
    },
