      "input": { "summary": "Review a PR that changes a server request handler." },
      "selection": { "baseline": ["naru-review-judge"], "selected": ["naru-review-backend", "naru-review-judge"], "skipped": ["naru-review-security", "naru-review-frontend-mobile", "naru-review-integrations", "naru-review-tests-ci"], "skippedStatus": "skipped-not-relevant" },
      "routing": { "root": { "profile": "terra", "variant": "high" }, "children": { "profiles": ["terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["post review"], "routes": ["naru-delegate-sol-xhigh-minion-debug"] },
      "expected": { "status": "completed", "authorization": "dry-run" }
    },
    {
      "id": "cross-service-review",
      "workflow": "review",
      "rootAgent": "naru-review",
      "input": { "summary": "Review a PR that changes an outbound webhook contract." },
      "selection": { "baseline": ["naru-review-judge"], "selected": ["naru-review-integrations", "naru-review-judge"], "skipped": ["naru-review-security", "naru-review-backend", "naru-review-frontend-mobile", "naru-review-tests-ci"], "skippedStatus": "skipped-not-relevant" },
      "routing": { "root": { "profile": "terra", "variant": "high" }, "children": { "profiles": ["terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["post review"], "routes": ["naru-delegate-sol-xhigh-minion-architect"] },
      "expected": { "status": "completed", "authorization": "dry-run" }
    },
    {
      "id": "provider-failure",
      "workflow": "plan",
      "rootAgent": "naru-plan",
      "input": { "summary": "Plan a focused bug fix; the tests specialist fails after one fresh retry." },
      "selection": { "baseline": ["naru-plan-minimal-change", "naru-plan-tests", "naru-plan-judge"], "selected": ["naru-plan-minimal-change", "naru-plan-tests", "naru-plan-judge"], "skipped": ["naru-plan-architecture", "naru-plan-risk"], "skippedStatus": "skipped-not-relevant" },
      "routing": { "root": { "profile": "terra", "variant": "high" }, "children": { "profiles": ["terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["automatic model fallback", "claim complete coverage"], "routes": ["naru-delegate-sol-xhigh-minion-implement"] },
      "expected": { "status": "partial", "authorization": "read-only", "failedSelected": ["naru-plan-tests"] }
    },
    {
      "id": "missing-context",
      "workflow": "plan",
      "rootAgent": "naru-plan",
      "input": { "summary": "" },
      "routing": { "root": { "profile": "terra", "variant": "high" }, "children": { "profiles": ["terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["invent scope", "delegate without objective"], "routes": ["naru-delegate-sol-xhigh-minion-implement"] },
      "expected": { "status": "clarification-required", "authorization": "read-only" }
    },
    {
      "id": "conditional-specialist-selection",
      "workflow": "impact",
      "rootAgent": "naru-impact",
      "input": { "summary": "Assess a local internal refactor with no data, API, or frontend surface." },
      "selection": { "baseline": ["naru-impact-topology", "naru-impact-tests-ci", "naru-impact-judge"], "selected": ["naru-impact-topology", "naru-impact-tests-ci", "naru-impact-judge"], "skipped": ["naru-impact-contracts", "naru-impact-data", "naru-impact-frontend-mobile"], "skippedStatus": "skipped-not-relevant" },
      "routing": { "root": { "profile": "terra", "variant": "high" }, "children": { "profiles": ["terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["mandatory all-specialist fan-out"], "routes": ["naru-delegate-sol-xhigh-minion-scout"] },
      "expected": { "status": "completed", "authorization": "read-only" }
    },
    {
      "id": "high-root-xhigh-denial",
      "workflow": "implementation",
      "rootAgent": "naru-orchestrator",
      "input": { "summary": "Use an xhigh child from a normal Sol high root." },
      "routing": { "root": { "profile": "sol", "variant": "high" }, "children": { "profiles": ["luna", "terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["automatic xhigh escalation"], "routes": ["naru-delegate-sol-xhigh-minion-implement"] },
      "expected": { "status": "denied", "authorization": "xhigh-root-required" }
    },
    {
      "id": "xhigh-root-optional-children",
      "workflow": "implementation",
      "rootAgent": "naru-orchestrator",
      "input": { "summary": "Direct Sol xhigh root may choose a high or xhigh implementation child." },
      "routing": { "root": { "profile": "sol", "variant": "xhigh" }, "children": { "profiles": ["luna", "terra", "sol"], "standardVariants": ["high"], "optionalVariants": ["xhigh"] } },
      "prohibited": { "actions": ["require xhigh child"], "routes": ["naru-delegate-sol-max-minion-implement"] },
      "expected": { "status": "completed", "authorization": "xhigh-authorized" }
    },
    {
      "id": "max-root-xhigh-unlock",
      "workflow": "implementation",
      "rootAgent": "naru-orchestrator",
      "input": { "summary": "Direct Sol max root may choose xhigh children, but no Max child exists." },
      "routing": { "root": { "profile": "sol", "variant": "max" }, "children": { "profiles": ["luna", "terra", "sol"], "standardVariants": ["high"], "optionalVariants": ["xhigh"] } },
      "prohibited": { "actions": ["create Max child"], "routes": ["naru-delegate-sol-max-minion-implement"] },
      "expected": { "status": "completed", "authorization": "xhigh-authorized" }
    },
    {
      "id": "routine-autonomous-local-commands",
      "workflow": "implementation",
      "rootAgent": "naru-orchestrator",
      "input": { "summary": "Implement a scoped local change and inspect status, metadata, and one targeted check." },
      "routing": { "root": { "profile": "sol", "variant": "high" }, "children": { "profiles": ["luna", "terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["database migration", "dependency update"], "routes": ["naru-delegate-sol-xhigh-minion-verify"] },
      "expected": { "status": "completed", "authorization": "authorized-local", "allowedOperations": ["naru-git-read", "naru-github-read", "bash", "weaver", "targeted-check"], "promptRequired": false }
    },
    {
      "id": "local-change-stopping-point",
      "workflow": "implementation",
      "rootAgent": "naru-orchestrator",
      "input": { "summary": "Implement and verify a scoped change; delivery was not requested." },
      "routing": { "root": { "profile": "sol", "variant": "high" }, "children": { "profiles": ["luna", "terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["commit", "push", "open pull request"], "routes": ["naru-delegate-sol-xhigh-minion-implement"] },
      "expected": { "status": "completed", "authorization": "local-changes-stop" }
    },
    {
      "id": "explicit-git-delivery",
      "workflow": "implementation",
      "rootAgent": "naru-orchestrator",
      "input": { "summary": "Implement, commit, push, and open a pull request for the approved scoped change." },
      "routing": { "root": { "profile": "sol", "variant": "high" }, "children": { "profiles": ["luna", "terra", "sol"], "standardVariants": ["high"], "optionalVariants": [] } },
      "prohibited": { "actions": ["unrequested migration", "scope expansion"], "routes": ["naru-delegate-sol-xhigh-minion-implement"] },
      "expected": { "status": "completed", "authorization": "delivery-authorized", "allowedOperations": ["commit", "push", "open-pull-request"], "promptRequired": false }
    }
  ],
  "implementationSchedulingCases": [
    {
      "id": "scheduler-single-writer",
      "scenario": "One ready implementation item does not create artificial fan-out.",
      "readyWorkItems": ["a"],
      "prohibitedActions": ["invent split"],
      "expected": { "implementWaves": [["a"]], "maxConcurrentImplement": 1, "disposition": "single-writer" }
    },
    {
      "id": "scheduler-safe-two-writer-wave",
      "scenario": "Two ready items have demonstrably disjoint ownership and claims.",
      "workItems": [
        { "workItemId": "a", "waveId": "wave-1", "baselineIdentity": "wave-1-pre", "baselineState": { "status": "clean", "changedPaths": [], "diffSnapshot": "empty" }, "dependencies": [], "ownedWriteScope": ["src/a.js"], "contractClaims": ["contract-a"], "generatedArtifactClaims": [], "mutableResourceClaims": ["resource-a"], "exclusions": ["src/b.js"], "verificationNeeds": ["check-a"] },
        { "workItemId": "b", "waveId": "wave-1", "baselineIdentity": "wave-1-pre", "baselineState": { "status": "clean", "changedPaths": [], "diffSnapshot": "empty" }, "dependencies": [], "ownedWriteScope": ["src/b.js"], "contractClaims": ["contract-b"], "generatedArtifactClaims": [], "mutableResourceClaims": ["resource-b"], "exclusions": ["src/a.js"], "verificationNeeds": ["check-b"] }
      ],
      "prohibitedActions": ["shared mutation"],
      "expected": { "implementWaves": [["a", "b"]], "maxConcurrentImplement": 2, "disposition": "concurrent" }
    },
    {
      "id": "scheduler-cap-two",
      "scenario": "Three independent ready items are bounded to two active writers.",
      "readyWorkItems": ["a", "b", "c"],
      "disjointAcross": ["writeScope", "dependencies", "contracts", "generatedArtifacts", "configuration", "resources"],
      "prohibitedActions": ["three concurrent writers"],
      "expected": { "implementWaves": [["a", "b"], ["c"]], "maxConcurrentImplement": 2, "disposition": "bounded" }
    },
    {
      "id": "scheduler-same-file-serialization",
      "scenario": "Ready items claim the same file.",
      "overlap": { "ownedWriteScope": ["src/shared.js"] },
      "prohibitedActions": ["concurrent same-file edit"],
      "expected": { "implementWaves": [["a"], ["b"]], "maxConcurrentImplement": 1, "disposition": "serialize" }
    },
    {
      "id": "scheduler-shared-contract-serialization",
      "scenario": "Ready items claim one shared interface contract.",
      "overlap": { "contractClaims": ["public-api-v1"] },
      "prohibitedActions": ["concurrent shared-contract edit"],
      "expected": { "implementWaves": [["a"], ["b"]], "maxConcurrentImplement": 1, "disposition": "serialize" }
    },
    {
      "id": "scheduler-shared-resource-serialization",
      "scenario": "Ready items claim one mutable runtime resource.",
      "overlap": { "mutableResourceClaims": ["dev-server:3000"] },
      "prohibitedActions": ["concurrent shared-resource use"],
      "expected": { "implementWaves": [["a"], ["b"]], "maxConcurrentImplement": 1, "disposition": "serialize" }
    },
    {
      "id": "scheduler-dependency-serialization",
      "scenario": "Item b depends on item a.",
      "dependencies": { "a": [], "b": ["a"] },
      "prohibitedActions": ["start dependent item early"],
      "expected": { "implementWaves": [["a"], ["b"]], "maxConcurrentImplement": 1, "disposition": "serialize" }
    },
    {
      "id": "scheduler-weaver-conflict",
      "scenario": "A live Weaver claim conflicts before item b can make its first edit.",
      "weaver": { "available": true, "conflictOn": "b", "requiredClaims": ["src/b.js"], "successfulClaims": [], "claimTiming": "before-first-edit", "claimRetries": 0 },
      "prohibitedActions": ["edit before all claims succeed", "rerun conflicting claim"],
      "expected": { "implementWaves": [["a"], ["b"]], "maxConcurrentImplement": 1, "editsBeforeConflict": 0, "reportChangedPaths": [], "coordinatorFallback": "serialized", "disposition": "blocked-then-serialize" }
    },
    {
      "id": "scheduler-weaver-unavailable-internal-gates",
      "scenario": "Weaver is unavailable but packet claims are strictly disjoint.",
      "weaver": { "available": false, "fallback": "strict-packet-ownership-and-changed-path-containment" },
      "prohibitedActions": ["relax ownership gates"],
      "expected": { "implementWaves": [["a", "b"]], "maxConcurrentImplement": 2, "disposition": "concurrent-with-internal-gates" }
    },
    {
      "id": "scheduler-aggregate-verification-barrier",
      "scenario": "Aggregate verification waits for both wave writers to terminate.",
      "wave": { "waveId": "wave-1", "writers": ["a", "b"] },
      "prohibitedActions": ["verify partial wave"],
      "expected": { "verificationStarts": "after-all-writers-terminal", "implementationReports": ["a", "b"], "claimComparison": "current-wave-delta-vs-current-wave-ownership-union" }
    },
    {
      "id": "scheduler-second-wave-baseline-delta",
      "scenario": "A second wave starts from a dirty baseline containing successful first-wave paths and verifies only its own delta while checking the full integrated state.",
      "wave": {
        "waveId": "wave-2",
        "workItemIds": ["c"],
        "baselineIdentity": "wave-2-pre",
        "baselineState": { "status": "dirty", "changedPaths": ["src/a.js", "src/b.js"], "diffSnapshot": "wave-1-diff" },
        "postWaveIdentity": "wave-2-post",
        "postWaveState": { "status": "dirty", "changedPaths": ["src/a.js", "src/b.js", "src/c.js"], "diffSnapshot": "wave-1-plus-wave-2-diff" },
        "currentWaveDelta": { "changedPaths": ["src/c.js"], "diffSnapshot": "wave-2-only-diff" },
        "ownershipUnion": ["src/c.js"]
      },
      "prohibitedActions": ["compare full dirty path set with current ownership", "classify earlier-wave paths as unknown"],
      "expected": { "verificationState": "full-integrated-post-wave-state", "claimComparison": "current-wave-delta-vs-current-wave-ownership-union", "earlierWavePaths": "valid-baseline-state", "disposition": "verified" }
    },
    {
      "id": "scheduler-scope-drift-invalidates-evidence",
      "scenario": "Owned-path drift and a later edit occur after aggregate verification.",
      "events": ["owned-path-drift", "later-edit"],
      "prohibitedActions": ["reuse stale verification", "reuse stale judgment"],
      "expected": { "evidenceStatus": "invalid", "invalidated": ["verification", "judgment"], "disposition": "block-and-reverify" }
    },
    {
      "id": "scheduler-remediation-delivery-serialized",
      "scenario": "Remediation and authorized delivery follow a completed writer wave.",
      "prohibitedActions": ["concurrent remediation", "delivery inside writer wave"],
      "expected": { "phases": ["implementation-wave", "aggregate-verification", "judgment", "serialized-remediation", "reverification", "rejudgment", "serialized-delivery"], "remediationConcurrency": 1, "deliveryConcurrency": 1 }
    },
    {
      "id": "scheduler-no-automatic-worktrees",
      "scenario": "Concurrency remains in the current workspace without automatic worktree creation.",
      "prohibitedActions": ["automatic worktree"],
      "expected": { "automaticWorktreeCreation": false, "workspaceMode": "current-workspace" }
    }
  ]
}
